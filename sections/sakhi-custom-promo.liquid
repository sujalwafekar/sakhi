{% comment %}
  Sakhi – Custom Dress Builder Promotion Section
  Showcases the 3-step custom dress process with CTA
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style sakhi-custom-promo"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="sakhi-custom-promo__inner">
    {% if section.settings.image != blank %}
      <div class="sakhi-custom-promo__image-wrapper">
        {{ section.settings.image | image_url: width: 800 | image_tag: class: 'sakhi-custom-promo__img', loading: 'lazy' }}
      </div>
    {% else %}
      <div class="sakhi-custom-promo__image-wrapper sakhi-custom-promo__image-wrapper--placeholder">
        {{ 'collection-1' | placeholder_svg_tag: 'sakhi-custom-promo__img placeholder-svg' }}
      </div>
    {% endif %}

    <div class="sakhi-custom-promo__content">
      {% if section.settings.eyebrow != blank %}
        <p class="sakhi-custom-promo__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 class="sakhi-custom-promo__title">
        {{ section.settings.heading | default: 'Design a Dress Just for Your Child' }}
      </h2>
      <p class="sakhi-custom-promo__desc">
        {{ section.settings.description | default: 'Create a one-of-a-kind dress your little one will love. Pick colors, sleeves, and even add their name.' }}
      </p>

      <div class="sakhi-custom-promo__steps">
        {% for block in section.blocks %}
          <div class="sakhi-custom-promo__step" {{ block.shopify_attributes }}>
            <div class="sakhi-custom-promo__step-num">{{ forloop.index }}</div>
            <div class="sakhi-custom-promo__step-icon">{{ block.settings.icon | default: '🎨' }}</div>
            <div class="sakhi-custom-promo__step-text">
              <h3 class="sakhi-custom-promo__step-title">{{ block.settings.title }}</h3>
              {% if block.settings.description != blank %}
                <p class="sakhi-custom-promo__step-desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.cta_label != blank %}
        <div class="sakhi-custom-promo__cta-wrapper">
          <a href="{{ section.settings.cta_link }}" class="sakhi-hero__btn sakhi-hero__btn--primary sakhi-custom-promo__cta">
            {{ section.settings.cta_label }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .sakhi-custom-promo {
    background: linear-gradient(135deg, #FFF0F3 0%, #F5F0FF 50%, #E8F4FD 100%);
  }

  .sakhi-custom-promo__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    background: #FFFFFF;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(44, 34, 32, 0.06);
  }

  @media screen and (min-width: 900px) {
    .sakhi-custom-promo__inner {
      flex-direction: row;
      gap: 0;
    }
  }

  .sakhi-custom-promo__image-wrapper {
    flex: 1;
    position: relative;
    min-height: 400px;
  }

  .sakhi-custom-promo__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sakhi-custom-promo__image-wrapper--placeholder {
    background: var(--sakhi-blush-light, #FFF0F3);
  }

  .sakhi-custom-promo__image-wrapper--placeholder svg {
    width: 100%;
    height: 100%;
    fill: var(--sakhi-blush, #C17A8E);
    opacity: 0.2;
  }

  .sakhi-custom-promo__content {
    flex: 1.2;
    padding: 40px 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media screen and (min-width: 900px) {
    .sakhi-custom-promo__content {
      padding: 60px 48px;
    }
  }

  .sakhi-custom-promo__eyebrow {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sakhi-blush, #C17A8E);
    margin-bottom: 12px;
    font-weight: 700;
  }

  .sakhi-custom-promo__title {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 700;
    color: var(--sakhi-warm-dark, #2C2220);
    margin-bottom: 16px;
    margin-top: 0;
    line-height: 1.1;
  }

  .sakhi-custom-promo__desc {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 16px;
    line-height: 1.7;
    color: var(--sakhi-warm-gray, #4A3F3A);
    margin-bottom: 40px;
    max-width: 500px;
  }

  .sakhi-custom-promo__steps {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
  }

  .sakhi-custom-promo__step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: var(--sakhi-blush-light, #FFF0F3);
    border-radius: 16px;
    border: 1px solid transparent;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sakhi-custom-promo__step:hover {
    transform: translateX(8px);
    box-shadow: 0 8px 24px rgba(193, 122, 142, 0.15);
    background: #FFFFFF;
    border-color: var(--sakhi-blush, #C17A8E);
  }

  .sakhi-custom-promo__step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--sakhi-blush, #C17A8E);
    color: #FFFFFF;
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .sakhi-custom-promo__step-icon {
    font-size: 24px;
    flex-shrink: 0;
    line-height: 1.2;
  }

  .sakhi-custom-promo__step-text {
    flex: 1;
  }

  .sakhi-custom-promo__step-title {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--sakhi-warm-dark, #2C2220);
    margin: 0 0 6px 0;
  }

  .sakhi-custom-promo__step-desc {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 14px;
    color: var(--sakhi-warm-gray, #4A3F3A);
    margin: 0;
    line-height: 1.5;
  }

  .sakhi-custom-promo__cta-wrapper {
    margin-top: 10px;
  }

  .sakhi-custom-promo__cta {
    display: inline-block !important;
    padding: 16px 40px !important;
    border-radius: 100px !important;
    font-family: var(--sakhi-font-body, 'Lora', serif) !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
    background: var(--sakhi-warm-dark, #2C2220) !important;
    color: #FFFFFF !important;
    border: 2px solid var(--sakhi-warm-dark, #2C2220) !important;
    transition: all 0.4s ease !important;
  }

  .sakhi-custom-promo__cta:hover {
    background: var(--sakhi-blush, #C17A8E) !important;
    border-color: var(--sakhi-blush, #C17A8E) !important;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(193, 122, 142, 0.3) !important;
  }

  @media screen and (max-width: 749px) {
    .sakhi-custom-promo__title {
      font-size: 28px;
    }
    .sakhi-custom-promo__desc {
      max-width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Dress Promo",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Promotion Image (Left Side)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "✂️ Personalize It"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design a Dress Just for Your Child"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Create a one-of-a-kind dress your little one will love. Pick colors, sleeves, and even add their name with hand embroidery."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Start Designing"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon emoji",
          "default": "🎨"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Step title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Step description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Dress Promo",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "🎨",
            "title": "Choose Color",
            "description": "Pick from pastel pink, lavender, sky blue, peach & more"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "👗",
            "title": "Choose Sleeve Style",
            "description": "Puff sleeves, flutter sleeves, sleeveless, or full sleeves"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "✨",
            "title": "Add Name Embroidery",
            "description": "Personalize with your child's name hand-stitched with love"
          }
        }
      ]
    }
  ]
}
{% endschema %}
