{% comment %}
  Sakhi – Hero Banner Section
  Full-width hero with headline, subheadline, two CTA buttons, floating animation
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style sakhi-hero-section"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  {% if section.settings.background_image != blank %}
    <div class="sakhi-hero__bg">
      {{ section.settings.background_image | image_url: width: 1920 | image_tag: alt: section.settings.heading, class: 'sakhi-hero__bg-img', loading: 'eager' }}
    </div>
  {% endif %}

  <div class="sakhi-hero__overlay"></div>

  <div class="sakhi-hero__content">
    {% if section.settings.eyebrow != blank %}
      <p class="sakhi-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <h1 class="sakhi-hero__heading">
      {{ section.settings.heading | default: 'Handmade Dresses for Your Little One' }}
    </h1>

    <p class="sakhi-hero__subheading">
      {{ section.settings.subheading | default: 'Beautiful frocks crafted with love and comfort.' }}
    </p>

    <div class="sakhi-hero__buttons">
      {% if section.settings.button_1_label != blank %}
        <a href="{{ section.settings.button_1_link }}" class="sakhi-hero__btn sakhi-hero__btn--primary">
          {{ section.settings.button_1_label }}
        </a>
      {% endif %}
      {% if section.settings.button_2_label != blank %}
        <a href="{{ section.settings.button_2_link }}" class="sakhi-hero__btn sakhi-hero__btn--secondary">
          {{ section.settings.button_2_label }}
        </a>
      {% endif %}
    </div>

    <div class="sakhi-hero__floating-elements">
      <span class="sakhi-hero__float sakhi-hero__float--1">🌸</span>
      <span class="sakhi-hero__float sakhi-hero__float--2">✨</span>
      <span class="sakhi-hero__float sakhi-hero__float--3">🎀</span>
      <span class="sakhi-hero__float sakhi-hero__float--4">💖</span>
    </div>
  </div>
</div>

{% stylesheet %}
  .sakhi-hero-section {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
    background: linear-gradient(135deg, #FFF0F3 0%, #F5F0FF 50%, #E8F4FD 100%);
  }

  .sakhi-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .sakhi-hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sakhi-hero__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 240, 243, 0.6) 0%,
      rgba(245, 240, 255, 0.5) 50%,
      rgba(255, 248, 243, 0.7) 100%
    );
    z-index: 1;
  }

  .sakhi-hero__content {
    position: relative;
    z-index: 10;
    max-width: 700px;
    padding: 40px 20px;
    animation: sakhi-hero-fade-in 1s ease both;
  }

  .sakhi-hero__eyebrow {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 13px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sakhi-blush, #C17A8E);
    margin-bottom: 16px;
    font-weight: 600;
  }

  .sakhi-hero__heading {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 48px;
    font-weight: 700;
    color: var(--sakhi-warm-dark, #2C2220);
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .sakhi-hero__subheading {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 18px;
    line-height: 1.7;
    color: var(--sakhi-warm-gray, #4A3F3A);
    margin-bottom: 36px;
    max-width: 520px;
    margin-inline: auto;
  }

  .sakhi-hero__buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .sakhi-hero__btn {
    display: inline-block;
    padding: 16px 36px;
    border-radius: 28px;
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .sakhi-hero__btn--primary {
    background: var(--sakhi-blush, #C17A8E);
    color: #FFFFFF;
    box-shadow: 0 4px 20px rgba(193, 122, 142, 0.3);
  }

  .sakhi-hero__btn--primary:hover {
    background: var(--sakhi-blush-dark, #A8637A);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(193, 122, 142, 0.4);
  }

  .sakhi-hero__btn--secondary {
    background: transparent;
    color: var(--sakhi-warm-dark, #2C2220);
    border: 2px solid var(--sakhi-blush, #C17A8E);
  }

  .sakhi-hero__btn--secondary:hover {
    background: var(--sakhi-blush, #C17A8E);
    color: #FFFFFF;
    transform: translateY(-2px);
  }

  /* Floating elements */
  .sakhi-hero__floating-elements {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .sakhi-hero__float {
    position: absolute;
    font-size: 28px;
    pointer-events: none;
    animation: sakhi-float 6s ease-in-out infinite;
    opacity: 0.6;
  }

  .sakhi-hero__float--1 { top: 15%; left: 8%; animation-delay: 0s; }
  .sakhi-hero__float--2 { top: 20%; right: 12%; animation-delay: 1.5s; }
  .sakhi-hero__float--3 { bottom: 25%; left: 15%; animation-delay: 3s; }
  .sakhi-hero__float--4 { bottom: 20%; right: 10%; animation-delay: 4.5s; }

  @keyframes sakhi-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-15px) rotate(5deg); }
    50% { transform: translateY(-8px) rotate(-3deg); }
    75% { transform: translateY(-20px) rotate(3deg); }
  }

  @keyframes sakhi-hero-fade-in {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media screen and (max-width: 749px) {
    .sakhi-hero-section {
      min-height: 70vh;
    }
    .sakhi-hero__heading {
      font-size: 32px;
    }
    .sakhi-hero__subheading {
      font-size: 16px;
    }
    .sakhi-hero__btn {
      padding: 14px 28px;
      font-size: 13px;
    }
    .sakhi-hero__float {
      font-size: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Sakhi Hero Banner",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "✨ Handcrafted with Love"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handmade Dresses for Your Little One"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Beautiful frocks crafted with love and comfort. Soft fabrics, unique designs, made just for your child."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 label",
      "default": "Shop Dresses"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label",
      "default": "Customize a Dress"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Sakhi Hero Banner"
    }
  ]
}
{% endschema %}
