{% comment %}
  Sakhi – Premium Split Hero Banner
  Left: Text & calls to action
  Right: Large high-quality featured image
  Floating playful elements added for emotional connection.
{% endcomment %}

<div class="sakhi-split-hero-wrapper color-{{ section.settings.color_scheme }}" style="{% render 'spacing-style', settings: section.settings %}">
  
  {% if section.settings.watermark_text != blank %}
    <div class="sakhi-split-hero__watermark">{{ section.settings.watermark_text }}</div>
  {% endif %}

  <div class="sakhi-split-hero page-width">
    
    {% comment %} Text Side (Left) {% endcomment %}
    <div class="sakhi-split-hero__text-area">
      {% if section.settings.eyebrow != blank %}
        <p class="sakhi-split-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      <h1 class="sakhi-split-hero__heading">
        {{ section.settings.heading | default: 'Handmade Dresses for Your Little One' }}
      </h1>

      <p class="sakhi-split-hero__subheading">
        {{ section.settings.subheading | default: 'Soft, beautiful frocks crafted with love and comfort.' }}
      </p>

      {% if section.settings.show_trust_badges %}
        <div class="sakhi-split-hero__trust-badges">
          <span class="sakhi-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Soft & Safe Fabric</span>
          <span class="sakhi-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Handmade</span>
          <span class="sakhi-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Made After Order</span>
          <span class="sakhi-hero-badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> 3–5 Day Prod.</span>
        </div>
      {% endif %}

      <div class="sakhi-split-hero__buttons">
        {% if section.settings.button_1_label != blank %}
          <a href="{{ section.settings.button_1_link }}" class="sakhi-split-hero__btn sakhi-split-hero__btn--primary">
            {{ section.settings.button_1_label }}
          </a>
        {% endif %}
        {% if section.settings.button_2_label != blank %}
          <a href="{{ section.settings.button_2_link }}" class="sakhi-split-hero__btn sakhi-split-hero__btn--secondary">
            {{ section.settings.button_2_label }}
          </a>
        {% endif %}
      </div>
    </div>

    {% comment %} Image Side (Right) {% endcomment %}
    <div class="sakhi-split-hero__image-area">
      <div class="sakhi-split-hero__image-wrapper">
        {% if section.settings.background_image != blank %}
          {{ section.settings.background_image | image_url: width: 1000 | image_tag: 
            class: 'sakhi-split-hero__img',
            loading: 'eager',
            alt: section.settings.heading 
          }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'sakhi-split-hero__img placeholder-svg' }}
        {% endif %}
      </div>
      
      {% comment %} Floating play elements around the image {% endcomment %}
      <div class="sakhi-split-hero__decorations">
        <span class="sakhi-float-decor sakhi-float-decor--1">🎀</span>
        <span class="sakhi-float-decor sakhi-float-decor--2">✨</span>
        <span class="sakhi-float-decor sakhi-float-decor--3">💖</span>
        <span class="sakhi-float-decor sakhi-float-decor--4">🌸</span>
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .sakhi-split-hero-wrapper {
    position: relative;
    overflow: hidden;
    padding-top: 60px;
    padding-bottom: 60px;
    background: linear-gradient(135deg, #FFF0F3 0%, #FFF8F3 100%);
  }

  .sakhi-split-hero {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 40px;
    position: relative;
    z-index: 2;
  }

  .sakhi-split-hero__text-area {
    flex: 1 1 400px;
    padding-right: 20px;
    animation: sakhi-slide-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .sakhi-split-hero__watermark {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    font-size: clamp(120px, 15vw, 240px);
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-weight: 800;
    color: var(--sakhi-watermark-color, rgba(193, 122, 142, 0.05));
    white-space: nowrap;
    z-index: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.02em;
  }

  /* Trust Badges */
  .sakhi-split-hero__trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 32px;
    max-width: 480px;
  }

  .sakhi-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--sakhi-border, #F0E4DC);
    padding: 6px 12px;
    border-radius: 100px;
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 13px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    box-shadow: 0 4px 12px rgba(44, 34, 32, 0.03);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .sakhi-hero-badge svg {
    width: 14px;
    height: 14px;
    color: var(--sakhi-gold, #D4A853);
  }

  .sakhi-split-hero__image-area {
    flex: 1 1 500px;
    position: relative;
    perspective: 1000px;
    animation: sakhi-fade-zoom 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* Typography */
  .sakhi-split-hero__eyebrow {
    font-family: var(--sakhi-font-body, 'Lora', serif) !important;
    font-size: 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sakhi-blush, #C17A8E);
    margin-bottom: 20px;
    font-weight: 700;
  }

  .sakhi-split-hero__heading {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif) !important;
    font-size: clamp(40px, 5vw, 64px) !important;
    font-weight: 700 !important;
    color: var(--sakhi-warm-dark, #2C2220) !important;
    line-height: 1.1 !important;
    margin-bottom: 24px !important;
    margin-top: 0 !important;
  }

  .sakhi-split-hero__subheading {
    font-family: var(--sakhi-font-body, 'Lora', serif) !important;
    font-size: clamp(16px, 2vw, 20px) !important;
    line-height: 1.6 !important;
    color: var(--sakhi-warm-gray, #4A3F3A) !important;
    margin-bottom: 40px !important;
    max-width: 480px;
  }

  /* Buttons */
  .sakhi-split-hero__buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .sakhi-split-hero__btn {
    display: inline-block !important;
    padding: 16px 40px !important;
    border-radius: 100px !important; /* Fully rounded premium feel */
    font-family: var(--sakhi-font-body, 'Lora', serif) !important;
    font-size: 15px !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
    cursor: pointer !important;
    text-align: center;
  }

  .sakhi-split-hero__btn--primary {
    background: var(--sakhi-blush, #C17A8E) !important;
    color: #FFFFFF !important;
    border: 2px solid var(--sakhi-blush, #C17A8E) !important;
    box-shadow: 0 8px 24px rgba(193, 122, 142, 0.3) !important;
  }

  .sakhi-split-hero__btn--primary:hover {
    background: var(--sakhi-blush-dark, #A8637A) !important;
    border-color: var(--sakhi-blush-dark, #A8637A) !important;
    transform: translateY(-3px) scale(1.02);
    box-shadow: 0 12px 32px rgba(193, 122, 142, 0.4) !important;
  }

  .sakhi-split-hero__btn--secondary {
    background: #FFFFFF !important;
    color: var(--sakhi-blush, #C17A8E) !important;
    border: 2px solid var(--sakhi-border, #F0E4DC) !important;
    box-shadow: 0 4px 16px rgba(44, 34, 32, 0.05) !important;
  }

  .sakhi-split-hero__btn--secondary:hover {
    background: var(--sakhi-blush-light, #FFF0F3) !important;
    color: var(--sakhi-blush-dark, #A8637A) !important;
    transform: translateY(-3px) scale(1.02);
  }

  /* Premium Image Wrapper */
  .sakhi-split-hero__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(44, 34, 32, 0.08);
    transform: rotate(-1.5deg); /* Subtle playful tilt */
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    background: #FFFFFF;
    border: 8px solid #FFFFFF;
  }

  .sakhi-split-hero__image-wrapper:hover {
    transform: rotate(0deg) translateY(-10px);
  }

  .sakhi-split-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 22px; /* Inner radius matching the border */
    display: block;
  }

  .sakhi-split-hero__img.placeholder-svg {
    background: var(--sakhi-gold-light, #F5E6C8);
    fill: var(--sakhi-gold, #D4A853);
    padding: 40px;
  }

  /* Floating Theme Elements */
  .sakhi-split-hero__decorations {
    position: absolute;
    inset: -40px;
    pointer-events: none;
    z-index: 10;
  }

  .sakhi-float-decor {
    position: absolute;
    font-size: 36px;
    animation: sakhi-wobble 4s ease-in-out infinite alternate;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.1));
  }

  .sakhi-float-decor--1 { top: 5%; left: -5%; animation-delay: 0s; font-size: 48px; }
  .sakhi-float-decor--2 { top: 15%; right: -2%; animation-delay: -1.2s; font-size: 32px; }
  .sakhi-float-decor--3 { bottom: 10%; left: -8%; animation-delay: -2s; font-size: 40px; }
  .sakhi-float-decor--4 { bottom: -2%; right: 10%; animation-delay: -0.7s; font-size: 44px; }

  /* Animations */
  @keyframes sakhi-slide-up {
    0% { opacity: 0; transform: translateY(40px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @keyframes sakhi-fade-zoom {
    0% { opacity: 0; transform: scale(0.95) translateZ(0); }
    100% { opacity: 1; transform: scale(1) translateZ(0); }
  }

  @keyframes sakhi-wobble {
    0% { transform: translateY(0) rotate(0deg) scale(1); }
    100% { transform: translateY(-15px) rotate(10deg) scale(1.1); }
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 989px) {
    .sakhi-split-hero {
      gap: 30px;
      text-align: center;
    }
    .sakhi-split-hero__text-area {
      padding-right: 0;
    }
    .sakhi-split-hero__subheading {
      margin-inline: auto;
    }
    .sakhi-split-hero__buttons {
      justify-content: center;
    }
    .sakhi-split-hero__image-wrapper {
      max-width: 80%;
      margin: 0 auto;
      aspect-ratio: 1 / 1;
      transform: rotate(0);
    }
    .sakhi-float-decor { display: none; } /* Hide floats on mobile to reduce clutter */
  }

  @media screen and (max-width: 749px) {
    .sakhi-split-hero-wrapper {
      padding-top: 30px;
      padding-bottom: 40px;
    }
    .sakhi-split-hero__image-wrapper {
      max-width: 100%;
      border-width: 4px;
    }
    .sakhi-split-hero__btn {
      width: 100%; /* Full width buttons on mobile */
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Sakhi Premium Hero",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Featured image (Right Side)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "✨ Handcrafted with Love"
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Background Watermark Text",
      "default": "sakhi"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show Trust Badges",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handmade Dresses for Your Little One"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Soft, beautiful frocks crafted with love and comfort."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Primary Button label",
      "default": "Shop Dresses"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Primary Button link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Secondary Button label",
      "default": "Customize a Dress"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Sakhi Premium Hero"
    }
  ]
}
{% endschema %}
