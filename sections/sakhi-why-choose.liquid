{% comment %}
  Sakhi – Why Parents Choose Sakhi Section
  4-column feature grid with editable icons and text
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="sakhi-why__header">
    <h2 class="sakhi-why__title">
      {{ section.settings.heading | default: 'Why Parents Choose Sakhi' }}
    </h2>
    {% if section.settings.subheading != blank %}
      <p class="sakhi-why__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
    <div class="sakhi-why__accent"></div>
  </div>

  <div class="sakhi-why__grid">
    {% for block in section.blocks %}
      <div class="sakhi-why__card" {{ block.shopify_attributes }}>
        <div class="sakhi-why__icon-wrap">
          {% if block.settings.custom_icon != blank %}
            {{ block.settings.custom_icon | image_url: width: 80 | image_tag: alt: block.settings.title, class: 'sakhi-why__icon-img' }}
          {% else %}
            <span class="sakhi-why__icon-emoji">{{ block.settings.icon | default: '🌿' }}</span>
          {% endif %}
        </div>
        <h3 class="sakhi-why__card-title">{{ block.settings.title }}</h3>
        <p class="sakhi-why__card-text">{{ block.settings.description }}</p>
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .sakhi-why__header {
    text-align: center;
    margin-bottom: 52px;
  }

  .sakhi-why__title {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 36px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    margin-bottom: 12px;
  }

  .sakhi-why__subtitle {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 16px;
    color: var(--sakhi-warm-gray, #4A3F3A);
    max-width: 480px;
    margin: 0 auto;
  }

  .sakhi-why__accent {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--sakhi-blush, #C17A8E), var(--sakhi-gold, #D4A853));
    margin: 18px auto 0;
    border-radius: 2px;
  }

  .sakhi-why__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    padding: 0 16px;
  }

  @media screen and (min-width: 750px) {
    .sakhi-why__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 36px;
      padding: 0;
    }
  }

  .sakhi-why__card {
    text-align: center;
    padding: 32px 20px;
    border-radius: 16px;
    background: linear-gradient(135deg, #FFFFFF 0%, #FFF8F3 100%);
    border: 1px solid var(--sakhi-border, #F0E4DC);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sakhi-why__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(193, 122, 142, 0.12);
    border-color: var(--sakhi-blush, #C17A8E);
  }

  .sakhi-why__icon-wrap {
    width: 72px;
    height: 72px;
    margin: 0 auto 20px;
    background: linear-gradient(135deg, var(--sakhi-blush-light, #FFF0F3), #F5F0FF);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sakhi-why__card:hover .sakhi-why__icon-wrap {
    transform: scale(1.1) rotate(5deg);
    background: linear-gradient(135deg, var(--sakhi-blush, #C17A8E), var(--sakhi-lavender, #9B7DC4));
  }

  .sakhi-why__icon-emoji {
    font-size: 32px;
    line-height: 1;
  }

  .sakhi-why__icon-img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .sakhi-why__card:hover .sakhi-why__icon-emoji {
    filter: brightness(1.2);
  }

  .sakhi-why__card-title {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    margin-bottom: 10px;
  }

  .sakhi-why__card-text {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 14px;
    line-height: 1.6;
    color: var(--sakhi-warm-gray, #4A3F3A);
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .sakhi-why__title {
      font-size: 28px;
    }
    .sakhi-why__card {
      padding: 24px 16px;
    }
    .sakhi-why__icon-wrap {
      width: 60px;
      height: 60px;
    }
    .sakhi-why__icon-emoji {
      font-size: 26px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Why Choose Sakhi",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Parents Choose Sakhi"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Made with care, worn with joy"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon emoji",
          "default": "🌿"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon image (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Sakhi",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "🧶",
            "title": "Soft Child-Friendly Fabric",
            "description": "Gentle, breathable fabrics selected to keep your child comfortable all day long."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✋",
            "title": "Handmade Craftsmanship",
            "description": "Each dress is carefully stitched by skilled artisans for superior quality and finish."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "💛",
            "title": "Comfortable Fit",
            "description": "Designed for easy movement so your child can play, walk, and stay comfortable."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "🎨",
            "title": "Unique Handmade Designs",
            "description": "Every dress features carefully designed patterns that make each piece stand out."
          }
        }
      ]
    }
  ]
}
{% endschema %}
