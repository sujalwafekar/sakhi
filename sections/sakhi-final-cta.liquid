{% comment %}
  Sakhi – Final CTA Section
  Call-to-action with animated gradient background and 2 buttons
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--full-width color-{{ section.settings.color_scheme }} spacing-style sakhi-cta-section"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="sakhi-cta__bg-gradient"></div>

  <div class="sakhi-cta__inner">
    <h2 class="sakhi-cta__title">{{ section.settings.heading | default: "Make Your Child's Outfit Special" }}</h2>
    {% if section.settings.subheading != blank %}
      <p class="sakhi-cta__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="sakhi-cta__buttons">
      {% if section.settings.button_1_label != blank %}
        <a href="{{ section.settings.button_1_link }}" class="sakhi-hero__btn sakhi-hero__btn--primary">
          {{ section.settings.button_1_label }}
        </a>
      {% endif %}
      {% if section.settings.button_2_label != blank %}
        <a href="{{ section.settings.button_2_link }}" class="sakhi-hero__btn sakhi-cta__btn--white">
          {{ section.settings.button_2_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .sakhi-cta-section {
    position: relative;
    padding: 80px 20px;
    text-align: center;
    overflow: hidden;
  }

  .sakhi-cta__bg-gradient {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      -45deg,
      #FFD6DF,
      #E6E0FF,
      #FFEBCA,
      #C17A8E
    );
    background-size: 400% 400%;
    animation: sakhi-gradient-anim 15s ease infinite;
    opacity: 0.2;
  }

  @keyframes sakhi-gradient-anim {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .sakhi-cta__inner {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  .sakhi-cta__title {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 40px;
    font-weight: 700;
    color: var(--sakhi-warm-dark, #2C2220);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .sakhi-cta__subtitle {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 16px;
    color: var(--sakhi-warm-gray, #4A3F3A);
    margin-bottom: 36px;
  }

  .sakhi-cta__buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .sakhi-cta__btn--white {
    background: #FFFFFF;
    color: var(--sakhi-warm-dark, #2C2220);
    border: 1px solid var(--sakhi-border, #F0E4DC);
    box-shadow: 0 4px 15px rgba(44, 34, 32, 0.05);
  }

  .sakhi-cta__btn--white:hover {
    background: var(--sakhi-blush-light, #FFF0F3);
    border-color: var(--sakhi-blush, #C17A8E);
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .sakhi-cta-section {
      padding: 60px 20px;
    }
    .sakhi-cta__title {
      font-size: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Final Call to Action",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Make Your Child's Outfit Special"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our collection of handmade ready-to-wear dresses or design a custom piece."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 label",
      "default": "Shop Dresses"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label",
      "default": "Customize a Dress"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Final Call to Action"
    }
  ]
}
{% endschema %}
