{% comment %}
  Sakhi - Category Strip
  Horizontal strip of circular category icons.
{% endcomment %}

<div class="sakhi-category-strip section-wrapper color-{{ section.settings.color_scheme }}" style="{% render 'spacing-style', settings: section.settings %}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="sakhi-category-strip__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="sakhi-category-strip__scroll-area">
      <div class="sakhi-category-strip__grid">
        {% for block in section.blocks %}
          <a href="{{ block.settings.collection.url | default: '#' }}" class="sakhi-category-strip__item" {{ block.shopify_attributes }}>
            <div class="sakhi-category-strip__image-wrapper">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 300 | image_tag: 
                  class: 'sakhi-category-strip__img',
                  loading: 'lazy',
                  alt: block.settings.title 
                }}
              {% elsif block.settings.collection != blank and block.settings.collection.image != blank %}
                {{ block.settings.collection.image | image_url: width: 300 | image_tag: 
                  class: 'sakhi-category-strip__img',
                  loading: 'lazy',
                  alt: block.settings.title 
                }}
              {% else %}
                <div class="sakhi-category-strip__placeholder">
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
            </div>
            <h3 class="sakhi-category-strip__title">{{ block.settings.title | default: block.settings.collection.title }}</h3>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .sakhi-category-strip {
    background: #FFFFFF;
    border-bottom: 1px solid var(--sakhi-border, #F0E4DC);
    padding: 30px 0;
  }

  .sakhi-category-strip__heading {
    text-align: center;
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 24px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    margin: 0 0 24px 0;
  }

  .sakhi-category-strip__scroll-area {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }

  .sakhi-category-strip__scroll-area::-webkit-scrollbar {
    display: none; /* Safari/Chrome */
  }

  .sakhi-category-strip__grid {
    display: flex;
    justify-content: center;
    gap: 30px;
    min-width: max-content;
    padding: 0 16px 16px 16px;
  }

  @media screen and (max-width: 749px) {
    .sakhi-category-strip__grid {
      justify-content: flex-start;
      gap: 20px;
    }
  }

  .sakhi-category-strip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    width: 110px;
    group: item;
  }

  @media screen and (min-width: 750px) {
    .sakhi-category-strip__item {
      width: 140px;
    }
  }

  .sakhi-category-strip__image-wrapper {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--sakhi-blush-light, #FFF0F3);
    overflow: hidden;
    margin-bottom: 12px;
    border: 3px solid #FFFFFF;
    box-shadow: 0 8px 20px rgba(193, 122, 142, 0.15);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .sakhi-category-strip__item:hover .sakhi-category-strip__image-wrapper {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 0 12px 25px rgba(193, 122, 142, 0.25);
    border-color: var(--sakhi-blush, #C17A8E);
  }

  .sakhi-category-strip__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sakhi-category-strip__item:hover .sakhi-category-strip__img {
    transform: scale(1.1);
  }

  .sakhi-category-strip__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sakhi-category-strip__placeholder svg {
    width: 50%;
    height: 50%;
    fill: var(--sakhi-blush, #C17A8E);
    opacity: 0.5;
  }

  .sakhi-category-strip__title {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    text-align: center;
    margin: 0;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .sakhi-category-strip__item:hover .sakhi-category-strip__title {
    color: var(--sakhi-blush-dark, #A8637A);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Strip",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image (Optional)"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Link to Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title Override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sakhi Category Strip",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Frocks"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Party Wear"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Custom Dresses"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "New Arrivals"
          }
        }
      ]
    }
  ]
}
{% endschema %}
