{% comment %}
  Sakhi Baby Store – Sample Categories Section
  This displays hardcoded sample baby clothing categories with placeholder SVG images.
  Replace these with real collections once your store is set up.
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div style="text-align: center; margin-bottom: 48px;">
    <h2 style="font-family: var(--sakhi-font-heading, 'Playfair Display', serif); font-size: 36px; font-weight: 600; color: var(--color-foreground-heading); margin-bottom: 12px;">
      {{ section.settings.heading | default: 'Shop by Category' }}
    </h2>
    <p style="font-family: var(--sakhi-font-body, 'Lora', serif); color: var(--color-foreground); font-size: 16px; max-width: 480px; margin: 0 auto;">
      {{ section.settings.subheading | default: 'Handpicked collections for your little ones' }}
    </p>
    <div style="width: 60px; height: 2px; background: linear-gradient(90deg, #C17A8E, #D4A853); margin: 18px auto 0; border-radius: 2px;"></div>
  </div>

  <div class="sakhi-categories-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="sakhi-category-card" {{ block.shopify_attributes }}>
        <div class="sakhi-category-image">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 400 | image_tag: alt: block.settings.title, class: 'sakhi-category-img' }}
          {% else %}
            <div class="sakhi-category-placeholder">
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'sakhi-category-svg' }}
            </div>
          {% endif %}
        </div>
        <h3 class="sakhi-category-title">{{ block.settings.title }}</h3>
        {% if block.settings.subtitle != blank %}
          <p class="sakhi-category-subtitle">{{ block.settings.subtitle }}</p>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .sakhi-categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 32px;
    padding: 0 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .sakhi-categories-grid {
      grid-template-columns: repeat(var(--sakhi-cat-cols, 4), 1fr);
      gap: 40px;
    }
  }

  .sakhi-category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sakhi-category-card:hover {
    transform: translateY(-6px);
  }

  .sakhi-category-image {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid #F0E4DC;
    box-shadow: 0 4px 20px rgba(44, 34, 32, 0.06);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    background: #FFF0F3;
  }

  @media screen and (min-width: 750px) {
    .sakhi-category-image {
      width: 170px;
      height: 170px;
    }
  }

  .sakhi-category-card:hover .sakhi-category-image {
    border-color: #C17A8E;
    box-shadow: 0 8px 30px rgba(193, 122, 142, 0.2);
    transform: scale(1.05);
  }

  .sakhi-category-img,
  .sakhi-category-svg,
  .sakhi-category-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sakhi-category-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #FFF0F3, #F5F0FF);
  }

  .sakhi-category-title {
    font-family: var(--font-body--family);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-foreground-heading);
    margin-top: 16px;
    margin-bottom: 2px;
  }

  .sakhi-category-subtitle {
    font-family: var(--font-body--family);
    font-size: 12px;
    color: var(--color-foreground);
    margin: 0;
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Sample Categories",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Handpicked collections for your little ones"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sample Categories",
      "category": "Collections",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Newborns",
            "subtitle": "0-6 months"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Infants",
            "subtitle": "6-12 months"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Toddlers",
            "subtitle": "1-3 years"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Kids",
            "subtitle": "3-5 years"
          }
        }
      ]
    }
  ]
}
{% endschema %}
