{% comment %}
  Sakhi – Parent Reviews Section
  Testimonial slider with parent name, review text, optional photo
{% endcomment %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style sakhi-reviews-section"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="sakhi-reviews__header">
    <h2 class="sakhi-reviews__title">
      {{ section.settings.heading | default: 'What Parents Are Saying' }}
    </h2>
    {% if section.settings.subheading != blank %}
      <p class="sakhi-reviews__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
    <div class="sakhi-reviews__accent"></div>
  </div>

  <div class="sakhi-reviews__slider-wrap">
    <div class="sakhi-reviews__slider" id="SakhiReviews-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="sakhi-reviews__slide" {{ block.shopify_attributes }}>
          <div class="sakhi-reviews__card">
            <div class="sakhi-reviews__stars">
              {% for i in (1..5) %}
                <span class="sakhi-reviews__star">★</span>
              {% endfor %}
            </div>
            <p class="sakhi-reviews__text">"{{ block.settings.text }}"</p>
            <div class="sakhi-reviews__author-wrap">
              <div class="sakhi-reviews__author-img-box">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 100 | image_tag: alt: block.settings.author, class: 'sakhi-reviews__author-img' }}
                {% else %}
                  <span class="sakhi-reviews__author-initial">{{ block.settings.author | slice: 0 }}</span>
                {% endif %}
              </div>
              <div class="sakhi-reviews__author-info">
                <p class="sakhi-reviews__author-name">{{ block.settings.author }}</p>
                <p class="sakhi-reviews__author-verified">Verified Buyer</p>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <button class="sakhi-reviews__nav sakhi-reviews__nav--prev" aria-label="Previous review">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button class="sakhi-reviews__nav sakhi-reviews__nav--next" aria-label="Next review">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>
</div>

{% stylesheet %}
  .sakhi-reviews__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .sakhi-reviews__title {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 36px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    margin-bottom: 12px;
  }

  .sakhi-reviews__subtitle {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 16px;
    color: var(--sakhi-warm-gray, #4A3F3A);
    max-width: 480px;
    margin: 0 auto;
  }

  .sakhi-reviews__accent {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, var(--sakhi-blush, #C17A8E), var(--sakhi-gold, #D4A853));
    margin: 18px auto 0;
    border-radius: 2px;
  }

  .sakhi-reviews__slider-wrap {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .sakhi-reviews__slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    gap: 24px;
    padding: 20px 0 40px;
  }

  .sakhi-reviews__slider::-webkit-scrollbar {
    display: none;
  }

  .sakhi-reviews__slide {
    flex: 0 0 100%;
    scroll-snap-align: center;
  }

  @media screen and (min-width: 750px) {
    .sakhi-reviews__slide {
      flex: 0 0 calc(50% - 12px);
    }
  }

  .sakhi-reviews__card {
    background: #FFFFFF;
    border-radius: 16px;
    padding: 32px;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--sakhi-border, #F0E4DC);
    box-shadow: 0 12px 30px rgba(44, 34, 32, 0.04);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .sakhi-reviews__card:hover {
    transform: translateY(-6px);
    border-color: var(--sakhi-blush, #C17A8E);
    box-shadow: 0 16px 40px rgba(193, 122, 142, 0.12);
  }

  .sakhi-reviews__stars {
    color: var(--sakhi-gold, #D4A853);
    font-size: 18px;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .sakhi-reviews__text {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 15px;
    line-height: 1.7;
    color: var(--sakhi-warm-gray, #4A3F3A);
    margin-bottom: 24px;
    flex-grow: 1;
    font-style: italic;
  }

  .sakhi-reviews__author-wrap {
    display: flex;
    align-items: center;
    gap: 16px;
    border-top: 1px solid var(--sakhi-border, #F0E4DC);
    padding-top: 20px;
  }

  .sakhi-reviews__author-img-box {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--sakhi-blush-light, #FFF0F3);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sakhi-blush, #C17A8E);
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-weight: 700;
    font-size: 20px;
  }

  .sakhi-reviews__author-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sakhi-reviews__author-name {
    font-family: var(--sakhi-font-heading, 'Playfair Display', serif);
    font-size: 15px;
    font-weight: 600;
    color: var(--sakhi-warm-dark, #2C2220);
    margin: 0 0 4px;
  }

  .sakhi-reviews__author-verified {
    font-family: var(--sakhi-font-body, 'Lora', serif);
    font-size: 12px;
    color: var(--sakhi-mint, #7BAE7F);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .sakhi-reviews__author-verified::before {
    content: '✓';
    font-weight: 700;
  }

  .sakhi-reviews__nav {
    position: absolute;
    top: 50%;
    transform: translateY(calc(-50% - 10px));
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #FFFFFF;
    border: 1px solid var(--sakhi-border, #F0E4DC);
    color: var(--sakhi-warm-dark, #2C2220);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(44, 34, 32, 0.08);
    transition: all 0.3s ease;
    z-index: 2;
  }

  .sakhi-reviews__nav:hover {
    background: var(--sakhi-blush, #C17A8E);
    color: #FFFFFF;
    border-color: var(--sakhi-blush, #C17A8E);
  }

  .sakhi-reviews__nav--prev { left: 0; }
  .sakhi-reviews__nav--next { right: 0; }

  @media screen and (max-width: 749px) {
    .sakhi-reviews__title { font-size: 28px; }
    .sakhi-reviews__slider-wrap { padding: 0; }
    .sakhi-reviews__nav { display: none; }
    .sakhi-reviews__slider { padding-left: 20px; padding-right: 20px; scroll-padding: 20px; }
  }
{% endstylesheet %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('SakhiReviews-{{ section.id }}');
    if (!slider) return;

    const prevBtn = slider.parentElement.querySelector('.sakhi-reviews__nav--prev');
    const nextBtn = slider.parentElement.querySelector('.sakhi-reviews__nav--next');
    
    if (prevBtn && nextBtn) {
      const scrollAmount = slider.clientWidth;

      prevBtn.addEventListener('click', () => {
        slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Parent Reviews",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Parents Are Saying"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Honest reviews from our lovely customers"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Review text",
          "default": "The dress was absolutely beautiful and fit perfectly. My daughter felt like a princess at her birthday party!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Parent's Name",
          "default": "Priya S."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Parent photo (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Parent Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "text": "The dress was absolutely beautiful and fit perfectly. The fabric is so soft, my daughter never wanted to take it off!",
            "author": "Priya S."
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "Such amazing handmade quality. The custom embroidery with her name made the outfit so incredibly special.",
            "author": "Meera T."
          }
        },
        {
          "type": "review",
          "settings": {
            "text": "I was looking for something unique for her birthday. This frock exceeded all my expectations. Highly recommend Sakhi!",
            "author": "Anjali K."
          }
        }
      ]
    }
  ]
}
{% endschema %}
